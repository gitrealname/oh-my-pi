start: cell+

cell: begin_cell attr* code_line* end_cell
begin_cell: "*** Begin " LANG LF
end_cell: "*** End Cell" LF?

attr: title | timeout | reset
title:   "*** Title: " /(.+)/ LF
timeout: "*** Timeout: " /\d+(ms|s|m)?/ LF
reset:   "*** Reset" LF

code_line: /[^\r\n]*/ LF

LANG: "JS" | "TS" | "PY"

%import common.LF
